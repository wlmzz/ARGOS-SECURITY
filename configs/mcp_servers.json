{
  "_comment": "ARGOS MCP Server Configuration — add servers here to extend ARGOS with external tools",
  "servers": {
    "filesystem": {
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/opt/argos/workspaces"],
      "env": {},
      "enabled": false,
      "_comment": "Local filesystem access — set enabled:true and adjust path"
    },
    "github": {
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {"GITHUB_TOKEN": "your_github_token_here"},
      "enabled": false,
      "_comment": "GitHub API — set GITHUB_TOKEN and enabled:true"
    },
    "postgres": {
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres"],
      "env": {"POSTGRES_CONNECTION_STRING": "postgresql://user:pass@localhost/db"},
      "enabled": false,
      "_comment": "PostgreSQL — set connection string and enabled:true"
    },
    "brave_search": {
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-brave-search"],
      "env": {"BRAVE_API_KEY": "your_brave_api_key"},
      "enabled": false,
      "_comment": "Brave Search API — alternative to SearXNG"
    },
    "slack": {
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-slack"],
      "env": {
        "SLACK_BOT_TOKEN": "xoxb-your-token",
        "SLACK_TEAM_ID": "your-team-id"
      },
      "enabled": false,
      "_comment": "Slack integration — read/write messages, channels"
    },
    "custom_http": {
      "transport": "http",
      "url": "http://localhost:3000/mcp",
      "enabled": false,
      "_comment": "Custom HTTP MCP server — change URL and enable"
    }
  }
}
